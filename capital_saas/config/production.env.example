APP_ENV=production
APP_VERSION=13.0.0
SECRET_KEY=replace-with-production-random-secret
DATABASE_URL=sqlite:///data/app.db
# DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/capital_saas?charset=utf8mb4
# DATABASE_URL=postgresql+psycopg2://user:password@127.0.0.1:5432/capital_saas
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=change-this-before-launch
AI_MODE=mock
OPENAI_MODEL=gpt-4.1-mini
PAYMENT_MODE=mock
NOTIFICATION_MODE=mock
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
LOGIN_RATE_LIMIT_PER_MINUTE=10
SECURITY_AUDIT_ENABLED=true
DATA_MASKING_ENABLED=true
REPORT_REVIEW_REQUIRED=true
BACKUP_RETENTION_DAYS=30
TRIAL_MODE=false
TRIAL_ALLOWED_IPS=
TRIAL_ACCESS_CODE=
SITE_BASE_URL=https://www.example.com
