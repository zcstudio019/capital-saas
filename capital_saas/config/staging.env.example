APP_ENV=staging
APP_VERSION=13.0.0
SECRET_KEY=replace-with-staging-random-secret
DATABASE_URL=sqlite:///data/staging.db
AI_MODE=mock
OPENAI_MODEL=gpt-4.1-mini
PAYMENT_MODE=mock
NOTIFICATION_MODE=mock
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
LOGIN_RATE_LIMIT_PER_MINUTE=20
REPORT_REVIEW_REQUIRED=true
TRIAL_MODE=true
TRIAL_ACCESS_CODE=staging-test
SITE_BASE_URL=https://staging.example.com
